# EduAI-Hub environment template.
# Safe to commit. Copy to .env.local for local development.
# Never put Supabase service-role keys or Coze API keys in VITE_* variables.

# Supabase browser credentials.
# These values must come from the current EduAI-Hub Supabase project, not an old project.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional browser/mobile Coze proxy URL.
# Leave blank for local dev and Vercel web so the app uses same-origin /api/coze.
# For packaged Android, set this to your deployed Vercel function URL, for example:
# VITE_COZE_PROXY_URL=https://your-vercel-domain.vercel.app/api/coze
VITE_COZE_PROXY_URL=

# Coze server-only credentials.
# These are read by /api/coze and the local Vite proxy only. Do not add VITE_ prefixes.
COZE_API_KEY=
# Optional alias if this project uses token naming instead of key naming.
COZE_API_TOKEN=

# Optional. Leave blank to use https://api.coze.com. Use https://api.coze.cn for Coze China accounts.
COZE_API_BASE_URL=

# Required for the three EduAI-Hub chatbot routes unless COZE_BOT_ID fallback is used.
COZE_PROMPT_THINKING_BOT_ID=
COZE_STUDY_PROMPT_BOT_ID=
COZE_PROMPT_EVALUATOR_BOT_ID=

# Legacy fallback names accepted during migration.
COZE_AI_GUIDE_BOT_ID=
COZE_GENERAL_PROMPT_BOT_ID=

# Optional fallback if one Coze bot should serve every chatbot route.
COZE_BOT_ID=

# Manual OAuth setup notes:
# 1. Supabase Dashboard -> Authentication -> Providers -> Google must be enabled.
# 2. Google OAuth redirect URI must be the current Supabase callback:
#    https://PROJECT_REF.supabase.co/auth/v1/callback
# 3. Supabase URL Configuration should include:
#    http://localhost:5173
#    http://localhost:5173/**
#    your production domain when deployed
