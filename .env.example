VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only (Vercel / local dev — do NOT use VITE_ prefix)
COZE_API_KEY=pat_your-personal-access-token
COZE_BOT_ID=your-default-bot-id-from-coze-url
# Optional per-chatbot bot IDs (fallback to COZE_BOT_ID)
COZE_BOT_ID_AI_GUIDE=
COZE_BOT_ID_STUDY_PROMPT=
COZE_BOT_ID_GENERAL_PROMPT=
# Use https://api.coze.cn if your bot/token is from coze.cn; default is api.coze.com
COZE_API_BASE=https://api.coze.com
